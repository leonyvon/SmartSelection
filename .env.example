# Environment Variables Example / 环境变量示例
# Copy this file to .env and fill in your configuration / 复制此文件为 .env 并填入你的配置

# API Key (optional, can also be configured in the app) / API Key (可选，也可以在应用中配置)
# VITE_API_KEY=sk-xxx

# API Base URL (optional) / API Base URL (可选)
# VITE_API_BASE_URL=https://api.openai.com/v1
